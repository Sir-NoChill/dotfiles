#!/usr/bin/env bash
# ngm - nginx configuration manager
# Usage: ngm <command> [name]

set -euo pipefail

# ---------------------------------------------------------------------------
# Configuration (override via environment variables)
# ---------------------------------------------------------------------------
NGM_SITES_AVAILABLE="${NGM_SITES_AVAILABLE:-/etc/nginx/sites-available}"
NGM_SITES_ENABLED="${NGM_SITES_ENABLED:-/etc/nginx/sites-enabled}"
NGM_DEFAULT_SCAFFOLD="${NGM_DEFAULT_SCAFFOLD:-/etc/nginx/default.conf}"
NGM_ERROR_LOG="${NGM_ERROR_LOG:-/var/log/nginx/error.log}"
NGM_LOG_LINES="${NGM_LOG_LINES:-50}"

# Commands that will be called via sudo — kept as variables so the test suite
# can override them with mock implementations without touching PATH tricks.
NGINX_CMD="${NGINX_CMD:-nginx}"
SYSTEMCTL_CMD="${SYSTEMCTL_CMD:-systemctl}"
EDITOR="${EDITOR:-vi}"

# ---------------------------------------------------------------------------
# Colour helpers (disabled when not a TTY)
# ---------------------------------------------------------------------------
if [ -t 1 ]; then
  RED=$'\033[0;31m'; GREEN=$'\033[0;32m'; YELLOW=$'\033[1;33m'
  CYAN=$'\033[0;36m'; BOLD=$'\033[1m'; RESET=$'\033[0m'
else
  RED=''; GREEN=''; YELLOW=''; CYAN=''; BOLD=''; RESET=''
fi

info()    { echo -e "${CYAN}[ngm]${RESET} $*"; }
success() { echo -e "${GREEN}[ngm]${RESET} $*"; }
warn()    { echo -e "${YELLOW}[ngm]${RESET} $*" >&2; }
die()     { echo -e "${RED}[ngm] error:${RESET} $*" >&2; exit 1; }

# ---------------------------------------------------------------------------
# Safety helpers
# ---------------------------------------------------------------------------

# Validate that a site name contains only safe characters.
# Allowed: alphanumerics, hyphens, underscores, and dots.
# This prevents path-traversal and shell-injection via the name argument.
validate_name() {
  local name="$1"
  if [[ -z "$name" ]]; then
    die "A site name is required for this command."
  fi
  if [[ ! "$name" =~ ^[A-Za-z0-9._-]+$ ]]; then
    die "Invalid site name '${name}'. Only letters, digits, '.', '-', and '_' are allowed."
  fi
  # Reject names that look like path traversal attempts
  if [[ "$name" == *".."* ]]; then
    die "Invalid site name '${name}'."
  fi
}

# Ensure nginx is reachable (under sudo) before commands that need it.
require_nginx() {
  if ! sudo "${NGINX_CMD}" -v &>/dev/null; then
    warn "nginx does not appear to be installed."
    suggest_install
    exit 1
  fi
}

suggest_install() {
  if command -v apt-get &>/dev/null; then
    info "Install nginx with: sudo apt-get install nginx"
  elif command -v dnf &>/dev/null; then
    info "Install nginx with: sudo dnf install nginx"
  elif command -v yum &>/dev/null; then
    info "Install nginx with: sudo yum install nginx"
  elif command -v pacman &>/dev/null; then
    info "Install nginx with: sudo pacman -S nginx"
  elif command -v brew &>/dev/null; then
    info "Install nginx with: brew install nginx"
  else
    info "Please install nginx using your system's package manager."
  fi
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

cmd_help() {
  cat <<EOF
${BOLD}ngm${RESET} — nginx configuration manager

${BOLD}USAGE${RESET}
  ngm <command> [site-name]

${BOLD}COMMANDS${RESET}
  new <name>       Create a new config from the scaffold template
  edit <name>      Open an existing config in \$EDITOR (uses sudo)
  enable <name>    Test config then symlink into sites-enabled
  disable <name>   Remove the symlink from sites-enabled
  delete <name>    Delete the config file (must be disabled first)
  list             List all configs, marking enabled ones with [✓]
  test             Run 'sudo nginx -t' to validate all configs
  restart          Restart the nginx systemd service
  reload           Reload the nginx systemd service (graceful)
  logs [lines]     Tail the nginx error log (default: ${NGM_LOG_LINES} lines)
  help             Show this help message

${BOLD}ENVIRONMENT${RESET}
  NGM_SITES_AVAILABLE   default: /etc/nginx/sites-available
  NGM_SITES_ENABLED     default: /etc/nginx/sites-enabled
  NGM_DEFAULT_SCAFFOLD  default: /etc/nginx/default.conf
  NGM_ERROR_LOG         default: /var/log/nginx/error.log
  NGM_LOG_LINES         default: 50
  EDITOR                editor used by 'edit' (default: vi)
EOF
}

cmd_new() {
  local name="${1:-}"
  validate_name "$name"

  local target="${NGM_SITES_AVAILABLE}/${name}.conf"

  # Check if it already exists (read via sudo to handle restricted dirs)
  if sudo test -e "$target"; then
    die "Config '${target}' already exists. Use 'ngm edit ${name}' to edit it."
  fi

  # Build scaffold content
  local scaffold
  if sudo test -f "${NGM_DEFAULT_SCAFFOLD}"; then
    info "Using scaffold: ${NGM_DEFAULT_SCAFFOLD}"
    scaffold="$(sudo cat "${NGM_DEFAULT_SCAFFOLD}")"
  else
    warn "Scaffold '${NGM_DEFAULT_SCAFFOLD}' not found — using built-in template."
    scaffold=$(cat <<'SCAFFOLD'
server {
    listen 80;
    listen [::]:80;

    server_name SITE_NAME;

    root /var/www/SITE_NAME/html;
    index index.html index.htm;

    access_log /var/log/nginx/SITE_NAME.access.log;
    error_log  /var/log/nginx/SITE_NAME.error.log;

    location / {
        try_files $uri $uri/ =404;
    }
}
SCAFFOLD
)
    scaffold="${scaffold//SITE_NAME/${name}}"
  fi

  echo "$scaffold" | sudo tee "$target" > /dev/null
  success "Created ${target}"
  info "Edit it with: ngm edit ${name}"
}

cmd_edit() {
  local name="${1:-}"
  validate_name "$name"

  local target="${NGM_SITES_AVAILABLE}/${name}.conf"

  if ! sudo test -f "$target"; then
    die "Config '${target}' does not exist. Create it with: ngm new ${name}"
  fi

  # sudoedit is the safest way to edit a privileged file: it copies the file
  # to a temp location, opens the editor as the unprivileged user, then
  # copies back — preventing the editor from running as root.
  # Fall back to "sudo $EDITOR" only if sudoedit is genuinely unavailable.
  if command -v sudoedit &>/dev/null; then
    EDITOR="$EDITOR" sudo --preserve-env=EDITOR,HOME,TERM \
      env SUDO_EDITOR="$EDITOR" sudoedit "$target"
  else
    warn "sudoedit not found — falling back to sudo \$EDITOR (editor will run as root)."
    sudo "$EDITOR" "$target"
  fi
}

cmd_enable() {
  local name="${1:-}"
  validate_name "$name"
  require_nginx

  local src="${NGM_SITES_AVAILABLE}/${name}.conf"
  local dst="${NGM_SITES_ENABLED}/${name}.conf"

  if ! sudo test -f "$src"; then
    die "Config '${src}' does not exist. Create it with: ngm new ${name}"
  fi

  if sudo test -e "$dst"; then
    warn "'${name}' is already enabled."
    return 0
  fi

  info "Testing nginx configuration…"
  if ! sudo "${NGINX_CMD}" -t; then
    die "nginx configuration test failed — aborting enable."
  fi

  sudo ln -s "$src" "$dst"
  success "Enabled: ${name}"
  info "Reload nginx to apply: ngm reload"
}

cmd_disable() {
  local name="${1:-}"
  validate_name "$name"

  local dst="${NGM_SITES_ENABLED}/${name}.conf"

  if ! sudo test -e "$dst"; then
    warn "'${name}' is not currently enabled."
    return 0
  fi

  sudo rm "$dst"
  success "Disabled: ${name}"
  info "Reload nginx to apply: ngm reload"
}

cmd_delete() {
  local name="${1:-}"
  validate_name "$name"

  local src="${NGM_SITES_AVAILABLE}/${name}.conf"
  local dst="${NGM_SITES_ENABLED}/${name}.conf"

  if ! sudo test -f "$src"; then
    die "Config '${src}' does not exist."
  fi

  if sudo test -e "$dst"; then
    die "'${name}' is still enabled. Run 'ngm disable ${name}' first."
  fi

  # Confirm before destructive action
  read -r -p "$(echo -e "${YELLOW}Delete ${src}? [y/N]${RESET} ")" confirm
  if [[ "${confirm,,}" != "y" ]]; then
    info "Aborted."
    return 0
  fi

  sudo rm "$src"
  success "Deleted: ${src}"
}

cmd_list() {
  if ! sudo test -d "${NGM_SITES_AVAILABLE}"; then
    die "Directory '${NGM_SITES_AVAILABLE}' not found. Is nginx installed?"
  fi

  info "Configurations in ${NGM_SITES_AVAILABLE}:"
  echo ""

  local found=0
  # Use sudo find to handle permission-restricted directories
  while IFS= read -r filepath; do
    local name
    name="$(basename "${filepath}" .conf)"
    local enabled_path="${NGM_SITES_ENABLED}/${name}.conf"
    if sudo test -e "$enabled_path"; then
      echo -e "  ${GREEN}[✓] ${name}${RESET}"
    else
      echo -e "  ${YELLOW}[ ] ${name}${RESET}"
    fi
    found=1
  done < <(sudo find "${NGM_SITES_AVAILABLE}" -maxdepth 1 -name "*.conf" | sort)

  if [[ "$found" -eq 0 ]]; then
    info "No .conf files found in ${NGM_SITES_AVAILABLE}"
  fi

  echo ""
  echo -e "  ${GREEN}[✓]${RESET} = enabled   ${YELLOW}[ ]${RESET} = disabled"
}

cmd_test() {
  require_nginx
  info "Testing nginx configuration…"
  sudo "${NGINX_CMD}" -t
}

cmd_restart() {
  info "Restarting nginx…"
  sudo "${SYSTEMCTL_CMD}" restart nginx
  success "nginx restarted."
}

cmd_reload() {
  info "Reloading nginx…"
  sudo "${SYSTEMCTL_CMD}" reload nginx
  success "nginx reloaded."
}

cmd_logs() {
  local lines="${1:-${NGM_LOG_LINES}}"

  # Validate that lines is a positive integer to prevent injection
  if [[ ! "$lines" =~ ^[0-9]+$ ]] || [[ "$lines" -lt 1 ]]; then
    die "Line count must be a positive integer, got: '${lines}'"
  fi

  if ! sudo test -f "${NGM_ERROR_LOG}"; then
    die "Error log not found: ${NGM_ERROR_LOG}"
  fi

  info "Last ${lines} lines of ${NGM_ERROR_LOG}:"
  sudo tail -n "$lines" "${NGM_ERROR_LOG}"
}

# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

main() {
  local command="${1:-help}"
  shift || true   # remaining args passed to subcommands

  case "$command" in
    new)     cmd_new     "$@" ;;
    edit)    cmd_edit    "$@" ;;
    enable)  cmd_enable  "$@" ;;
    disable) cmd_disable "$@" ;;
    delete)  cmd_delete  "$@" ;;
    list)    cmd_list    "$@" ;;
    test)    cmd_test    "$@" ;;
    restart) cmd_restart "$@" ;;
    reload)  cmd_reload  "$@" ;;
    logs)    cmd_logs    "$@" ;;
    help|--help|-h) cmd_help ;;
    *)
      warn "Unknown command: '${command}'"
      echo ""
      cmd_help
      exit 1
      ;;
  esac
}

main "$@"
